# ─── Supabase ──────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
ADMIN_EMAILS=gm@example.com

# ─── Game Server ───────────────────────────────────────────
# Public game server URL used by the browser.
# Leave blank if your deployed site reverse-proxies the game server on the same origin.
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_SERVER_URL=

# URL the game server allows connections from (your frontend URL)
CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
SOCKET_ALLOWED_ORIGINS=http://localhost:3000

# ─── Game Settings ─────────────────────────────────────────
ACTION_TIMEOUT_SECONDS=30
BETWEEN_HAND_DELAY_SECONDS=5

# ─── Ko-fi Chip Shop ────────────────────────────────────────
# Set KOFI_ENABLED=true when you are ready to open the shop.
# Leave as false to show "Coming Soon" to players.
KOFI_ENABLED=false

# From Ko-fi → Settings → API → Verification Token
KOFI_VERIFICATION_TOKEN=your-kofi-verification-token

# Resend (https://resend.com) — free up to 3,000 emails/month
# Used to email chip codes to buyers after Ko-fi payment
RESEND_API_KEY=re_your_resend_api_key

# The "from" address in code emails (must be a domain you verify in Resend)
EMAIL_FROM=chips@yourdomain.com

# Frontend env vars (copy to frontend/.env.local too)
NEXT_PUBLIC_KOFI_ENABLED=false
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/yourusername
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_MAIN_SITE_URL=https://arcanastudiolabs.com

